# OpenRouter API Configuration
# Copy this file to .env and populate with your actual values

# Required: Your OpenRouter API key from https://openrouter.ai/settings/keys
OPENROUTER_API_KEY=sk_live_...

# Required: The model ID to use by default (e.g., "anthropic/claude-sonnet-4.5")
# Full list: https://openrouter.ai/models
MODEL_ID=anthropic/claude-sonnet-4.5

# Optional: Application title for attribution to OpenRouter
APP_TITLE=OpenRouter FastAPI Service

# Optional: Application URL for attribution to OpenRouter
APP_URL=http://localhost:8000

# Optional: Environment stage (development, staging, production)
ENVIRONMENT=development

# Optional: Enable verbose logging
LOG_LEVEL=INFO
